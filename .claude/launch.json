{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["place.api.app:app", "--reload", "--port", "8000"],
      "cwd": "backend",
      "port": 8000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "web",
      "port": 3000
    },
    {
      "name": "design-preview",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "4173", "--directory", "design"],
      "port": 4173
    }
  ]
}
