# ============================================================
# Works now — dev defaults; override only if your setup differs
# ============================================================

# Runtime DSN (asyncpg); alembic derives the sync psycopg URL from it
DATABASE_URL=postgresql+asyncpg://place:place@localhost:5433/place
# Compose postgres credentials (host port 5433 -> container 5432)
POSTGRES_USER=place
POSTGRES_PASSWORD=place
POSTGRES_DB=place
# Signs magic-link tokens and session cookies (itsdangerous).
# REQUIRED in any real deployment (>= 32 chars); generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
# Left unset, the backend uses a per-process random key (dev only: sessions
# and magic links do not survive restarts, and multi-worker setups break).
SECRET_KEY=
# Sent on all outbound API calls (Overpass requires a real User-Agent)
HTTP_USER_AGENT=place-backend/0.1 (+https://github.com/parthivnair/place)
# Allowed browser origin for the Next.js PWA
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
# Founder allowlist for /admin routes (users has no is_founder column yet)
FOUNDER_EMAIL=
# Magic-link / session token lifetimes (seconds); defaults are fine for dev
#MAGIC_LINK_MAX_AGE_S=900
#SESSION_MAX_AGE_S=15552000
# From-address for magic-link email (only used when RESEND_API_KEY is set)
#MAGIC_LINK_FROM=Place <onboarding@resend.dev>
# Set true behind TLS in prod so the session cookie is Secure
#SESSION_COOKIE_SECURE=false
# Ingest download cache and evaluator lockfile (defaults are fine for dev)
#DATA_CACHE_DIR=backend/data/cache
#EVALUATOR_LOCKFILE=/tmp/place-evaluator.lock

# ============================================================
# Fill later — key-gated; absent key => component skips with a
# MissingCredential log, never fakes a response
# ============================================================

# recreation.gov RIDB facilities API (https://ridb.recreation.gov)
RIDB_API_KEY=
# Claude extraction worker + entity-resolution embeddings
ANTHROPIC_API_KEY=
# Reddit official API (script app) for corpus fetch
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
# AirNow AQI (smoke-season suppression)
AIRNOW_API_KEY=
# Resend transactional email for magic links (dev mode logs the link instead)
RESEND_API_KEY=
# Sentry error tracking
SENTRY_DSN=
# Web Push VAPID keypair (generate: python -m place.api.vapid_keygen)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
# mailto: contact for push services
VAPID_SUBJECT=
