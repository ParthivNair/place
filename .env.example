# ============================================================
# Works now — dev defaults; override only if your setup differs
# ============================================================

# Runtime DSN (asyncpg); alembic derives the sync psycopg URL from it
DATABASE_URL=postgresql+asyncpg://place:place@localhost:5433/place
# Compose postgres credentials (host port 5433 -> container 5432)
POSTGRES_USER=place
POSTGRES_PASSWORD=place
POSTGRES_DB=place
# Signs magic-link tokens and session cookies (itsdangerous).
# REQUIRED in any real deployment (>= 32 chars); generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
# Left unset, the backend uses a per-process random key (dev only: sessions
# and magic links do not survive restarts, and multi-worker setups break).
SECRET_KEY=
# Sent on all outbound API calls (Overpass requires a real User-Agent)
HTTP_USER_AGENT=place-backend/0.1 (+https://github.com/parthivnair/place)
# Allowed browser origin for the Next.js PWA
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
# Founder allowlist for /admin routes (users has no is_founder column yet)
FOUNDER_EMAIL=
# pre-revenue extraction provider — cheapest quality option; ~$35 seed run
DEEPSEEK_API_KEY=
# auto = deepseek when DEEPSEEK_API_KEY is set, else anthropic when
# ANTHROPIC_API_KEY is set. Setting this to "anthropic" is the switch-back
# at revenue time (explicit values require their key).
EXTRACTION_PROVIDER=auto
# DeepSeek knobs (defaults are fine)
#DEEPSEEK_MODEL=deepseek-v4-pro
#DEEPSEEK_BASE_URL=https://api.deepseek.com
#DEEPSEEK_CONCURRENCY=8
# Magic-link / session token lifetimes (seconds); defaults are fine for dev
#MAGIC_LINK_MAX_AGE_S=900
#SESSION_MAX_AGE_S=15552000
# From-address for magic-link email (only used when RESEND_API_KEY is set)
#MAGIC_LINK_FROM=Place <onboarding@resend.dev>
# Set true behind TLS in prod so the session cookie is Secure
#SESSION_COOKIE_SECURE=false
# Ingest download cache and evaluator lockfile (defaults are fine for dev)
#DATA_CACHE_DIR=backend/data/cache
#EVALUATOR_LOCKFILE=/tmp/place-evaluator.lock

# ============================================================
# Fill later — key-gated; absent key => component skips with a
# MissingCredential log, never fakes a response
# ============================================================

# recreation.gov RIDB facilities API (https://ridb.recreation.gov)
RIDB_API_KEY=
# Claude extraction worker + entity-resolution embeddings
ANTHROPIC_API_KEY=
# Reddit official API for corpus fetch. NOTE: since Nov 2025 Reddit's
# Responsible Builder Policy requires pre-approval for all Data API access —
# file the non-commercial request via the "Developer Platform & Accessing
# Reddit Data" article on support.reddithelp.com (~2-4 weeks), then create a
# "script" type app at https://old.reddit.com/prefs/apps (old UI is the
# reliable form). Redirect uri is required but unused by our app-only auth:
# enter http://localhost:8080. About URL can be left blank.
# Not blocking: the Oregon Hikers corpus fetch is keyless and richer for the
# Gorge — extraction can run on it while Reddit approval is pending.
# USER_AGENT format Reddit expects: platform:app-id:version (by /u/yourname)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=macos:place-corpus-fetch:v0.1 (by /u/your_reddit_username)
# AirNow AQI (smoke-season suppression)
AIRNOW_API_KEY=
# Resend transactional email for magic links (dev mode logs the link instead)
RESEND_API_KEY=
# Sentry error tracking
SENTRY_DSN=

# Web-push keypair — self-generated, no external service. Run:
#   make vapid SUBJECT=mailto:you@example.com
# (must use the project venv; a bare `python -m place.api.vapid_keygen`
# fails outside it with missing cryptography/py_vapid)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
# mailto: contact for push services
VAPID_SUBJECT=
